@style

h1.test
  color black
  &:hover
    color red

---
@head

<style>
body { background: yellowgreen; }
</style>
---
@template

<h1 class="test">Hello world</h1>

$layout|test:
  <p>Should be rendered inside the "test" layout</p>

$component|hello { message: "Hello world" }
  <h1 slot="header">This component has a title and a message.</h1>