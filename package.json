{
  "private": true,
  "name": "cogspinner",
  "module": "main.ts",
  "type": "module",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/html-parser": "^0.11.5",
    "@types/js-yaml": "^4.0.9",
    "@types/stylus": "^0.48.43",
    "concurrently": "^9.1.2",
    "html-parser": "^0.11.0",
    "rimraf": "^6.0.1",
    "stylus": "^0.64.0",
    "wait-on": "^8.0.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "hono": "^4.7.2",
    "jsdom": "^26.0.0"
  },
  "scripts": {
    "dev": "conc \"bun dev:app\" \"bun dev:tasks\" --names \"app,tasks\" --prefix-colors \"cyan,yellow\"",
    "dev:cleaner": "rimraf --glob \"artifacts/*\"",
    "dev:app": "wait-on artifacts/routes.ts && bun --watch main.ts",
    "dev:tasks": "bun --watch gears/routines/index.ts -d"
  }
}