{
  "private": true,
  "name": "cogspinner",
  "module": "main.ts",
  "type": "module",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "hono": "^4.7.2"
  },
  "scripts": {
    "dev": "conc \"bun dev:app\" \"bun dev:tasks\" --names \"app,tasks\" --prefix-colors \"cyan,yellow\"",
    "dev:app": "bun --no-clear-screen --watch main.ts",
    "dev:tasks": "bun --no-clear-screen --watch \"gears/routines/index.ts\""
  }
}